    </CalendarTrigger>

  </Triggers>

  <Actions Context="Author">

    <Exec>

      <Command>C:\Users\David Wu\AppData\Local\Programs\Python\Python312\python.exe</Command>

      <Arguments>-m environments.demo.ruppert_cycle crypto_1d</Arguments>

      <WorkingDirectory>C:\Users\David Wu\.openclaw\workspace</WorkingDirectory>

    </Exec>

